<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Salva Ciudadana — Panel Municipal de Reportes Ciudadanos</title>
<meta name="description" content="Panel municipal para gestionar reportes ciudadanos de alcantarillas tapadas y centros de acopio llenos, con mapa interactivo y seguimiento de estado.">
<meta name="theme-color" content="#0a0f0a">
<link rel="icon" href="data:,">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  :root{
    --bg:#0a0f0a;
    --bg-soft:#10160f;
    --panel:#131a12;
    --panel-2:#161f14;
    --border:#1f2a1d;
    --text:#e8efe6;
    --text-dim:#8fa085;
    --accent:#5fe05f;
    --accent-dim:#1f5c2c;
    --alta:#f0524a;
    --media:#f0c84a;
    --baja:#4ac8f0;
    --terminado:#4ac880;
    --pendiente:#f0a020;
    --radius:10px;
    --radius-lg:16px;
    font-size:16px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;height:100%;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    overflow:hidden;
  }
  .visually-hidden{
    position:absolute;width:1px;height:1px;overflow:hidden;
    clip:rect(0 0 0 0);white-space:nowrap;
  }
  a,button,input{font-family:inherit;}
  button{cursor:pointer;}
  :focus-visible{outline:2px solid var(--accent);outline-offset:2px;}

  /* ─── HEADER ─────────────────────────────────── */
  header{
    height:60px;
    display:flex;align-items:center;justify-content:space-between;
    padding:0 20px;
    background:var(--bg-soft);
    border-bottom:1px solid var(--border);
    position:relative;z-index:10;
  }
  .logo{display:flex;align-items:center;gap:10px;}
  .logo-icon{
    width:32px;height:32px;border-radius:9px;
    background:linear-gradient(135deg,var(--accent-dim),var(--accent));
    display:flex;align-items:center;justify-content:center;font-size:17px;
    box-shadow:0 0 14px rgba(95,224,95,.25);
  }
  .logo-text{font-size:19px;font-weight:700;letter-spacing:.2px;}
  .logo-text span{color:var(--accent);}
  .header-right{display:flex;align-items:center;gap:10px;}
  .modo-badge{
    font-size:11.5px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;
    padding:5px 10px;border-radius:20px;border:1px solid;
  }
  .modo-badge.lectura{color:var(--media);border-color:var(--media);background:rgba(240,200,74,.08);}
  .modo-badge.escritura{color:var(--terminado);border-color:var(--terminado);background:rgba(74,200,128,.08);}
  .badge{
    font-size:11.5px;font-weight:700;letter-spacing:.6px;
    padding:5px 10px;border-radius:6px;
    background:#000;border:1px solid var(--accent-dim);color:var(--accent);
  }
  .header-right button{
    background:transparent;color:var(--text);
    border:1px solid var(--border);border-radius:8px;
    padding:7px 13px;font-size:13.5px;font-weight:500;
    transition:border-color .15s,background .15s;
  }
  .header-right button:hover{border-color:var(--accent-dim);background:var(--panel-2);}

  /* ─── LAYOUT ─────────────────────────────────── */
  .main{display:flex;height:calc(100vh - 60px);}
  .sidebar{
    width:380px;min-width:300px;
    background:var(--bg-soft);
    border-right:1px solid var(--border);
    display:flex;flex-direction:column;
    overflow:hidden;
  }
  .sidebar-header{padding:18px 18px 12px;border-bottom:1px solid var(--border);}
  .sidebar-title{font-size:12.5px;text-transform:uppercase;letter-spacing:.8px;color:var(--text-dim);margin-bottom:10px;}
  .stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:12px;}
  .stat{
    background:var(--panel);border:1px solid var(--border);border-radius:var(--radius);
    padding:10px 6px;text-align:center;border-top:2.5px solid transparent;
  }
  .stat.alta{border-top-color:var(--alta);}
  .stat.media{border-top-color:var(--media);}
  .stat.baja{border-top-color:var(--baja);}
  .stat-num{font-size:22px;font-weight:700;}
  .stat.alta .stat-num{color:var(--alta);}
  .stat.media .stat-num{color:var(--media);}
  .stat.baja .stat-num{color:var(--baja);}
  .stat-label{font-size:10.5px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.4px;margin-top:2px;}

  .filtros{display:flex;flex-wrap:wrap;gap:6px;padding:0 18px 14px;border-bottom:1px solid var(--border);}
  .filtro-btn{
    background:var(--panel);border:1px solid var(--border);color:var(--text-dim);
    border-radius:20px;padding:6px 12px;font-size:12.5px;font-weight:500;
    transition:all .15s;
  }
  .filtro-btn:hover{border-color:var(--accent-dim);color:var(--text);}
  .filtro-btn.active{background:var(--accent-dim);border-color:var(--accent);color:#eafff0;}

  .lista-reportes{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;}
  .reporte-card{
    background:var(--panel);border:1px solid var(--border);border-left:3px solid var(--border);
    border-radius:var(--radius);padding:12px 13px;cursor:pointer;
    transition:border-color .15s,transform .1s;
  }
  .reporte-card:hover{border-color:#2a3a27;transform:translateY(-1px);}
  .reporte-card.alta{border-left-color:var(--alta);}
  .reporte-card.media{border-left-color:var(--media);}
  .reporte-card.baja{border-left-color:var(--baja);}
  .card-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:6px;}
  .card-tipo{font-size:14px;font-weight:600;}
  .card-prioridad{font-size:10.5px;font-weight:700;text-transform:uppercase;padding:3px 8px;border-radius:5px;white-space:nowrap;}
  .card-prioridad.alta{background:rgba(240,82,74,.15);color:var(--alta);}
  .card-prioridad.media{background:rgba(240,200,74,.15);color:var(--media);}
  .card-prioridad.baja{background:rgba(74,200,240,.15);color:var(--baja);}
  .card-desc{font-size:13px;color:var(--text-dim);line-height:1.4;margin-bottom:6px;}
  .card-coords{font-family:ui-monospace,Menlo,monospace;font-size:11px;color:#5a6a55;margin-bottom:8px;}
  .card-estado{display:inline-block;font-size:11px;font-weight:600;padding:3px 9px;border-radius:20px;margin-bottom:10px;}
  .card-estado.nuevo{background:rgba(255,255,255,.07);color:#cfd8cc;}
  .card-estado.pendiente{background:rgba(240,160,32,.13);color:var(--pendiente);}
  .card-estado.terminado{background:rgba(74,200,128,.13);color:var(--terminado);}
  .card-acciones{display:flex;gap:7px;}
  .btn-accion{
    flex:1;border:1px solid var(--border);background:var(--panel-2);color:var(--text);
    border-radius:7px;padding:7px 8px;font-size:12px;font-weight:600;
    transition:border-color .15s,opacity .15s;
  }
  .btn-iniciar:hover:not(:disabled){border-color:var(--pendiente);color:var(--pendiente);}
  .btn-finalizar:hover:not(:disabled){border-color:var(--terminado);color:var(--terminado);}
  .btn-accion:disabled{opacity:.35;cursor:not-allowed;}
  .btn-accion.cargando{opacity:.6;cursor:wait;}

  .empty-state{text-align:center;padding:50px 16px;color:var(--text-dim);}
  .empty-state .icon{font-size:32px;margin-bottom:8px;}

  /* ─── MAPA ───────────────────────────────────── */
  #map{flex:1;background:#0a0f0a;}
  .leaflet-popup-content-wrapper{background:#10160f;color:var(--text);border-radius:10px;}
  .leaflet-popup-tip{background:#10160f;}
  .popup-tipo{font-weight:700;font-size:14px;margin-bottom:6px;}
  .popup-row{font-size:12.5px;color:var(--text-dim);margin-bottom:3px;}
  .popup-prioridad,.popup-estado{font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px;margin-right:6px;display:inline-block;}
  .popup-estado.nuevo{background:rgba(255,255,255,.08);color:#cfd8cc;}
  .popup-estado.pendiente{background:rgba(240,160,32,.15);color:var(--pendiente);}
  .popup-estado.terminado{background:rgba(74,200,128,.15);color:var(--terminado);}

  /* ─── TOAST ──────────────────────────────────── */
  #toast{
    position:fixed;bottom:24px;left:50%;
    transform:translate(-50%,16px);
    background:#10160f;border:1px solid var(--border);color:var(--text);
    padding:11px 20px;border-radius:30px;font-size:13.5px;font-weight:500;
    opacity:0;pointer-events:none;transition:opacity .2s,transform .2s;
    box-shadow:0 8px 24px rgba(0,0,0,.4);z-index:200;
  }
  #toast.show{opacity:1;transform:translate(-50%,0);}
  #toast.ok{border-color:var(--terminado);}
  #toast.error{border-color:var(--alta);}
  #toast.info{border-color:var(--pendiente);}

  /* ─── LOADING ────────────────────────────────── */
  #loading{
    position:fixed;inset:0;background:var(--bg);
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;
    z-index:999;
  }
  .spinner{
    width:34px;height:34px;border-radius:50%;
    border:3px solid var(--border);border-top-color:var(--accent);
    animation:spin 0.8s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg);}}
  #loading p{color:var(--text-dim);font-size:13.5px;}

  /* ─── MODAL CONFIG ───────────────────────────── */
  #modal-config{
    position:fixed;inset:0;background:rgba(0,0,0,.6);
    display:none;align-items:center;justify-content:center;z-index:150;padding:16px;
  }
  .modal-box{
    background:var(--bg-soft);border:1px solid var(--border);border-radius:var(--radius-lg);
    max-width:560px;width:100%;max-height:88vh;overflow-y:auto;padding:24px 26px;
  }
  .modal-title{font-size:18px;font-weight:700;margin-bottom:8px;}
  .modal-sub{font-size:13px;color:var(--text-dim);line-height:1.5;margin-bottom:18px;}
  .tabs{display:flex;gap:6px;border-bottom:1px solid var(--border);margin-bottom:16px;}
  .tab-btn{
    background:transparent;border:none;color:var(--text-dim);
    padding:9px 4px;font-size:13px;font-weight:600;border-bottom:2px solid transparent;
    margin-right:14px;
  }
  .tab-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
  .tab-panel{display:none;}
  .tab-panel.active{display:block;}
  .steps-list{display:flex;flex-direction:column;gap:8px;margin-bottom:16px;}
  .step{font-size:13px;color:var(--text-dim);line-height:1.5;}
  .step b{color:var(--text);}
  .step code{background:var(--panel);padding:2px 6px;border-radius:5px;color:var(--accent);font-size:12px;}
  .code-block-wrap{position:relative;}
  .code-block{
    background:#080c08;border:1px solid var(--border);border-radius:8px;
    padding:14px;max-height:240px;overflow:auto;
    font-family:ui-monospace,Menlo,Consolas,monospace;font-size:11.5px;line-height:1.5;
    color:#bcd6b8;white-space:pre;
  }
  .btn-copiar{
    position:absolute;top:8px;right:8px;
    background:var(--panel-2);border:1px solid var(--border);color:var(--text);
    border-radius:6px;padding:5px 10px;font-size:11.5px;
  }
  .btn-copiar:hover{border-color:var(--accent-dim);}
  .config-field{margin-bottom:14px;}
  .config-label{display:block;font-size:12.5px;color:var(--text-dim);margin-bottom:6px;}
  .config-input{
    width:100%;background:var(--panel);border:1px solid var(--border);color:var(--text);
    border-radius:8px;padding:9px 11px;font-size:13px;
  }
  .config-input:focus{border-color:var(--accent-dim);}
  .config-btns{display:flex;gap:10px;margin-top:18px;flex-wrap:wrap;}
  .btn-modal-ok{
    background:var(--accent);color:#08130a;border:none;border-radius:8px;
    padding:10px 18px;font-size:13.5px;font-weight:700;
  }
  .btn-modal-ok:hover{background:#74e874;}
  .btn-modal-sec{
    background:transparent;color:var(--text-dim);border:1px solid var(--border);
    border-radius:8px;padding:10px 18px;font-size:13.5px;font-weight:500;
  }
  .btn-modal-sec:hover{color:var(--text);}

  /* ─── RESPONSIVE ─────────────────────────────── */
  @media (max-width:880px){
    .logo-text{font-size:16px;}
    .badge{display:none;}
    .header-right button{padding:6px 9px;font-size:12px;}
    .main{flex-direction:column;height:auto;min-height:calc(100vh - 60px);}
    .sidebar{width:100%;min-width:0;height:46vh;border-right:none;border-bottom:1px solid var(--border);}
    #map{height:54vh;}
  }

  @media (prefers-reduced-motion:reduce){
    *{animation-duration:.001s !important;transition-duration:.001s !important;}
  }
</style>
</head>
<body>

<h1 class="visually-hidden">Salva Ciudadana — Panel municipal de reportes ciudadanos</h1>

<iframe id="proxy-frame" title="Conexión con Apps Script" style="display:none" aria-hidden="true"></iframe>

<div id="loading">
  <div class="spinner" role="status" aria-label="Cargando"></div>
  <p>Cargando reportes…</p>
</div>

<div id="toast" role="status" aria-live="polite"></div>

<div id="modal-config" role="dialog" aria-modal="true" aria-labelledby="modal-title-text">
  <div class="modal-box">
    <div class="modal-title" id="modal-title-text">⚙️ Configurar Salva Ciudadana</div>
    <div class="modal-sub">Para que los botones <strong style="color:var(--text)">Iniciar</strong> y <strong style="color:var(--text)">Finalizar</strong> escriban en tu Google Sheet, necesitas un Apps Script desplegado como web app.</div>
    <div class="tabs">
      <button class="tab-btn active" onclick="cambiarTab('paso1', this)">1. Apps Script</button>
      <button class="tab-btn" onclick="cambiarTab('paso2', this)">2. URL &amp; Columnas</button>
    </div>
    <div class="tab-panel active" id="tab-paso1">
      <div class="steps-list">
        <div class="step"><b>1.</b> Abre tu Google Sheet → <code>Extensiones → Apps Script</code></div>
        <div class="step"><b>2.</b> Borra el contenido y pega el código de abajo</div>
        <div class="step"><b>3.</b> Guarda (<code>Ctrl+S</code>) → <code>Implementar → Nueva implementación</code></div>
        <div class="step"><b>4.</b> Tipo: <b>Aplicación web</b> | Ejecutar como: <b>Yo</b> | Acceso: <b>Cualquier persona</b></div>
        <div class="step"><b>5.</b> Autoriza permisos y copia la <b>URL de implementación</b></div>
        <div class="step"><b>6.</b> Ve a pestaña <b>2. URL &amp; Columnas</b> y pega la URL</div>
      </div>
      <div class="code-block-wrap">
        <button class="btn-copiar" onclick="copiarScript()">⎘ Copiar</button>
        <div class="code-block" id="codigo-script">var SHEET_NAME = "Hoja 1";

function doGet(e) { return manejarPeticion(e); }
function doPost(e) { return manejarPeticion(e); }

function manejarPeticion(e) {
  try {
    var params = e.parameter;
    if (params.action === "updateEstado") {
      return respuesta(actualizarEstado(params));
    }
    if (params.action === "addReporte") {
      return respuesta(agregarReporte(params));
    }
    return respuesta({ success: false, error: "Accion desconocida" });
  } catch (err) {
    return respuesta({ success: false, error: err.message });
  }
}

function respuesta(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

function agregarReporte(params) {
  var ss    = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(SHEET_NAME);
  if (!sheet) return { success: false, error: "Hoja no encontrada: " + SHEET_NAME };

  var headers = sheet.getDataRange().getValues()[0].map(function(h) {
    return h.toString().toLowerCase().trim();
  });

  var id = new Date().getTime().toString();
  var fila = [];

  headers.forEach(function(h) {
    switch (h) {
      case "id":          fila.push(id); break;
      case "tipo":        fila.push(params.tipo || ""); break;
      case "descripcion": fila.push(params.descripcion || ""); break;
      case "prioridad":   fila.push(params.prioridad || ""); break;
      case "latitud":     fila.push(params.lat || ""); break;
      case "longitud":    fila.push(params.lng || ""); break;
      case "estado":      fila.push("Pendiente"); break;
      case "fecha":       fila.push(new Date()); break;
      case "foto":        fila.push(params.foto || ""); break;
      default:            fila.push("");
    }
  });

  sheet.appendRow(fila);
  return { success: true, id: id };
}

function actualizarEstado(params) {
  var ss    = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(SHEET_NAME);
  if (!sheet) return { success: false, error: "Hoja no encontrada: " + SHEET_NAME };

  var rowId       = params.rowId;
  var colId       = params.colId;
  var colEstado   = params.colEstado;
  var nuevoEstado = params.estado;

  var data    = sheet.getDataRange().getValues();
  var headers = data[0].map(function(h){ return h.toString().toLowerCase().trim(); });

  var idxEstado = headers.indexOf(colEstado.toLowerCase().trim());
  if (idxEstado === -1) {
    idxEstado = headers.length;
    sheet.getRange(1, idxEstado + 1).setValue(colEstado);
  }

  var targetRow = -1;
  if (colId && colId !== "id") {
    var idxId = headers.indexOf(colId.toLowerCase().trim());
    if (idxId !== -1) {
      for (var i = 1; i < data.length; i++) {
        if (data[i][idxId].toString() === rowId.toString()) {
          targetRow = i + 1;
          break;
        }
      }
    }
  }
  if (targetRow === -1) {
    var rowNum = parseInt(rowId);
    if (!isNaN(rowNum) && rowNum >= 2 && rowNum <= data.length + 1) {
      targetRow = rowNum;
    }
  }
  if (targetRow === -1) return { success: false, error: "Fila no encontrada: " + rowId };

  sheet.getRange(targetRow, idxEstado + 1).setValue(nuevoEstado);
  return { success: true, row: targetRow, estado: nuevoEstado };
}</div>
      </div>
      <div class="config-btns">
        <button class="btn-modal-ok" onclick="cambiarTab('paso2', document.querySelectorAll('.tab-btn')[1])">Siguiente → URL &amp; Columnas</button>
