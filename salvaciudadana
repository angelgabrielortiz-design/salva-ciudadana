<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  /* ─── CONFIGURACIÓN POR DEFECTO (ya lista para este proyecto) ── */
  const SHEET_ID = '1FMiW2WD9A-FAEGZLAKBELVWgn2yLi_Oqr3dsmINrMXk';
  const URL_CSV  = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=Hoja 1`;
  const SCRIPT_URL_DEFAULT = 'https://script.google.com/macros/s/AKfycbzXoPjYOq2EDOoR6WNX2BID8BjB_DpD2dJJ8Rwj3uK244t9tjkrQy2bxYZZ-Ypra9dJ/exec';

  let SCRIPT_URL  = localStorage.getItem('eco_script_url') || SCRIPT_URL_DEFAULT;
  let COL_ESTADO  = localStorage.getItem('eco_col_estado') || 'estado';
  let COL_ID      = localStorage.getItem('eco_col_id') || 'id';
  let modoLectura = !SCRIPT_URL;

  let mapa, reportes = [], markers = [], filtroActual = 'todos';

  let iframeCallId = 0;

  /* ─── IFRAME PROXY ───────────────────────────────
     Apps Script no permite fetch directo por CORS.
     Cargamos la URL en un iframe oculto: el script SÍ
     se ejecuta y escribe en el Sheet, aunque no podamos
     leer la respuesta (cross-origin).
  ────────────────────────────────────────────────── */
  function llamarScriptViaIframe(url) {
    return new Promise((resolve, reject) => {
      const frame = document.getElementById('proxy-frame');
      ++iframeCallId;

      const timer = setTimeout(() => {
        frame.onload = null;
        frame.onerror = null;
        reject(new Error('Tiempo de espera agotado'));
      }, 10000);

      frame.onload = () => {
        clearTimeout(timer);
        frame.onload = null;
        frame.onerror = null;
        resolve({ success: true });
      };

      frame.onerror = () => {
        clearTimeout(timer);
        frame.onload = null;
        frame.onerror = null;
        reject(new Error('Error de red'));
      };

      frame.src = url;
    });
  }

  /* ─── MODAL / TABS ─────────────────────────────── */
  function abrirConfig() {
    document.getElementById('modal-config').style.display = 'flex';
    document.getElementById('input-script-url').value = SCRIPT_URL;
    document.getElementById('input-col-estado').value = COL_ESTADO;
    document.getElementById('input-col-id').value = COL_ID;
  }

  function cambiarTab(id, btn) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + id).classList.add('active');
    btn.classList.add('active');
  }

  function copiarScript() {
    navigator.clipboard.writeText(document.getElementById('codigo-script').textContent).then(() => {
      const btn = document.querySelector('.btn-copiar');
      btn.textContent = '✓ Copiado';
      setTimeout(() => { btn.textContent = '⎘ Copiar'; }, 2000);
    });
  }

  function guardarConfig() {
    const url   = document.getElementById('input-script-url').value.trim();
    const col   = document.getElementById('input-col-estado').value.trim() || 'estado';
    const colId = document.getElementById('input-col-id').value.trim() || 'id';
    if (!url) { mostrarToast('⚠️ Ingresa la URL del Apps Script', 'error'); return; }
    SCRIPT_URL = url; COL_ESTADO = col; COL_ID = colId; modoLectura = false;
    localStorage.setItem('eco_script_url', url);
    localStorage.setItem('eco_col_estado', col);
    localStorage.setItem('eco_col_id', colId);
    document.getElementById('modal-config').style.display = 'none';
    actualizarModoBadge();
    mostrarToast('✅ Configuración guardada', 'ok');
    cargarDatos();
  }

  function saltarConfig() {
    modoLectura = true;
    document.getElementById('modal-config').style.display = 'none';
    actualizarModoBadge();
    cargarDatos();
  }

  function actualizarModoBadge() {
    const el = document.getElementById('modo-indicator');
    if (modoLectura) { el.textContent = 'Solo lectura'; el.className = 'modo-badge lectura'; }
    else { el.textContent = '✓ Escritura activa'; el.className = 'modo-badge escritura'; }
  }

  if (SCRIPT_URL) {
    document.getElementById('modal-config').style.display = 'none';
    actualizarModoBadge();
  }

  /* ─── MAPA ─────────────────────────────────────── */
  mapa = L.map('map', { zoomControl: false }).setView([20.5, -100.5], 10);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '© OpenStreetMap © CARTO', subdomains: 'abcd', maxZoom: 19
  }).addTo(mapa);
  L.control.zoom({ position: 'bottomright' }).addTo(mapa);

  /* ─── HELPERS ───────────────────────────────────── */
  function getPrioridad(p) {
    if (!p) return 'baja';
    p = p.toLowerCase();
    if (p.includes('alta')) return 'alta';
    if (p.includes('media')) return 'media';
    return 'baja';
  }

  function getEstado(e) {
    if (!e) return 'nuevo';
    e = e.toLowerCase().trim();
    if (e.includes('terminado') || e.includes('completado') || e.includes('finalizado')) return 'terminado';
    if (e.includes('pendiente') || e.includes('iniciado') || e.includes('proceso')) return 'pendiente';
    return 'nuevo';
  }

  function getEstadoLabel(e) {
    const s = getEstado(e);
    if (s === 'terminado') return '✓ Terminado';
    if (s === 'pendiente') return '⏳ Pendiente';
    return '● Nuevo';
  }

  function getColor(p) {
    if (p === 'alta') return '#f0524a';
    if (p === 'media') return '#f0c84a';
    return '#4ac8f0';
  }

  function crearIcono(prioridad, estado) {
    const color = getColor(prioridad);
    const ring  = getEstado(estado) === 'terminado' ? '#4ac880' : getEstado(estado) === 'pendiente' ? '#f0a020' : 'white';
    return L.divIcon({
      html: `<div style="width:14px;height:14px;background:${color};border:2px solid ${ring};border-radius:50%;box-shadow:0 0 8px ${color}88;"></div>`,
      className: '', iconSize: [14, 14], iconAnchor: [7, 7]
    });
  }

  /* ─── TOAST ─────────────────────────────────────── */
  let toastTimer;
  function mostrarToast(msg, tipo = 'ok') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = `show ${tipo}`;
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 3500);
  }

  /* ─── CSV PARSER ────────────────────────────────── */
  function parsearCSV(texto) {
    const lineas = texto.trim().split('\n');
    const encabezados = lineas[0].split(',').map(h => h.replace(/"/g, '').trim().toLowerCase());
    return lineas.slice(1).map((linea, rowIndex) => {
      const vals = [];
      let dentro = false, campo = '';
      for (let c of linea) {
        if (c === '"') { dentro = !dentro; continue; }
        if (c === ',' && !dentro) { vals.push(campo); campo = ''; continue; }
        campo += c;
      }
      vals.push(campo);
      const obj = { _rowIndex: rowIndex + 2 };
      encabezados.forEach((h, i) => { obj[h] = (vals[i] || '').trim(); });
      return obj;
    });
  }

  /* ─── ACTUALIZAR ESTADO ─────────────────────────── */
  async function actualizarEstado(reporte, nuevoEstado, btnI, btnF) {
    if (modoLectura) {
      mostrarToast('⚠️ Activa la escritura en ⚙ Config', 'error');
      return;
    }

    btnI.classList.add('cargando'); btnF.classList.add('cargando');
    btnI.textContent = '...'; btnF.textContent = '...';

    try {
      const rowId = COL_ID !== 'id' && reporte[COL_ID] ? reporte[COL_ID] : reporte._rowIndex;
      const params = new URLSearchParams({
        action:    'updateEstado',
        rowId:     rowId,
        colId:     COL_ID,
        colEstado: COL_ESTADO,
        estado:    nuevoEstado
      });

      const url = `${SCRIPT_URL}?${params.toString()}`;
      await llamarScriptViaIframe(url);

      reporte[COL_ESTADO] = nuevoEstado;
      mostrarToast(
        nuevoEstado === 'Pendiente' ? '⏳ Marcado como Pendiente' : '✅ Marcado como Terminado',
        nuevoEstado === 'Pendiente' ? 'info' : 'ok'
      );
      renderLista(reportesFiltrados());
      renderMapa(reportesFiltrados());

    } catch (err) {
      mostrarToast(`❌ ${err.message}`, 'error');
    } finally {
      btnI.classList.remove('cargando');
      btnF.classList.remove('cargando');
    }
  }

  /* ─── FILTROS ───────────────────────────────────── */
  function reportesFiltrados() {
    if (filtroActual === 'todos') return reportes;
    return reportes.filter(r =>
      r.tipo?.toLowerCase().includes(filtroActual.toLowerCase()) ||
      r.prioridad?.toLowerCase().includes(filtroActual.toLowerCase()) ||
      getEstado(r[COL_ESTADO]).includes(filtroActual.toLowerCase())
    );
  }

  function filtrar(tipo, btn) {
    filtroActual = tipo;
    document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderLista(reportesFiltrados());
    renderMapa(reportesFiltrados());
  }

  /* ─── RENDER LISTA ──────────────────────────────── */
  function renderLista(datos) {
    const lista = document.getElementById('lista');
    if (!datos.length) {
      lista.innerHTML = `<div class="empty-state"><div class="icon">📍</div><p>No hay reportes</p></div>`;
      return;
    }
    lista.innerHTML = '';
    datos.forEach(r => {
      const p   = getPrioridad(r.prioridad);
      const est = getEstado(r[COL_ESTADO]);
      const lat = parseFloat(r.latitud), lng = parseFloat(r.longitud);
      const ok  = !isNaN(lat) && !isNaN(lng);

      const card = document.createElement('div');
      card.className = `reporte-card ${p}`;
      card.innerHTML = `
        <div class="card-top">
          <div class="card-tipo">${r.tipo || 'Sin tipo'}</div>
          <span class="card-prioridad ${p}">${r.prioridad || 'Baja'}</span>
        </div>
        <div class="card-desc">${r.descripcion || 'Sin descripción'}</div>
        ${ok ? `<div class="card-coords">${lat.toFixed(4)}, ${lng.toFixed(4)}</div>` : ''}
        <span class="card-estado ${est}">${getEstadoLabel(r[COL_ESTADO])}</span>
        <div class="card-acciones">
          <button class="btn-accion btn-iniciar" ${est === 'pendiente' || est === 'terminado' ? 'disabled' : ''}>▶ Iniciar</button>
          <button class="btn-accion btn-finalizar" ${est === 'terminado' ? 'disabled' : ''}>✓ Finalizar</button>
        </div>`;

      card.addEventListener('click', e => {
        if (e.target.classList.contains('btn-accion')) return;
        if (ok) { const idx = reportes.indexOf(r); mapa.setView([lat, lng], 16); markers[idx]?.openPopup(); }
      });

      const btnI = card.querySelector('.btn-iniciar');
      const btnF = card.querySelector('.btn-finalizar');
      btnI.addEventListener('click', e => { e.stopPropagation(); actualizarEstado(r, 'Pendiente', btnI, btnF); });
      btnF.addEventListener('click', e => { e.stopPropagation(); actualizarEstado(r, 'Terminado', btnI, btnF); });

      lista.appendChild(card);
    });
  }

  /* ─── RENDER MAPA ───────────────────────────────── */
  function renderMapa(datos) {
    markers.forEach(m => m && mapa.removeLayer(m));
    markers = [];
    const bounds = [];
    reportes.forEach(r => {
      const lat = parseFloat(r.latitud), lng = parseFloat(r.longitud);
      if (isNaN(lat) || isNaN(lng)) { markers.push(null); return; }
      const p = getPrioridad(r.prioridad);
      const marker = L.marker([lat, lng], { icon: crearIcono(p, r[COL_ESTADO]) });
      marker.bindPopup(`
        <div class="popup-tipo">${r.tipo || 'Sin tipo'}</div>
        <div class="popup-row"><strong>Descripción:</strong> ${r.descripcion || '—'}</div>
        <div class="popup-row"><strong>Coords:</strong> ${lat.toFixed(5)}, ${lng.toFixed(5)}</div>
        <div style="margin-top:8px;">
          <span class="popup-prioridad ${p}" style="background:${getColor(p)}22;color:${getColor(p)}">${r.prioridad || 'Baja'}</span>
          <span class="popup-estado ${getEstado(r[COL_ESTADO])}">${getEstadoLabel(r[COL_ESTADO])}</span>
        </div>`);
      if (datos.includes(r)) { marker.addTo(mapa); bounds.push([lat, lng]); }
      markers.push(marker);
    });
    if (bounds.length) mapa.fitBounds(bounds, { padding: [40, 40] });
  }

  /* ─── STATS ─────────────────────────────────────── */
  function actualizarStats(datos) {
    document.getElementById('cnt-alta').textContent  = datos.filter(r => getPrioridad(r.prioridad) === 'alta').length;
    document.getElementById('cnt-media').textContent = datos.filter(r => getPrioridad(r.prioridad) === 'media').length;
    document.getElementById('cnt-baja').textContent  = datos.filter(r => getPrioridad(r.prioridad) === 'baja').length;
  }

  /* ─── CARGAR DATOS ──────────────────────────────── */
  async function cargarDatos() {
    try {
      document.getElementById('btn-actualizar').textContent = '↻ Cargando...';
      const res   = await fetch(URL_CSV);
      const texto = await res.text();
      reportes = parsearCSV(texto).filter(r => r.tipo || r.descripcion);
      actualizarStats(reportes);
      renderLista(reportesFiltrados());
      renderMapa(reportesFiltrados());
    } catch (e) {
      document.getElementById('lista').innerHTML = `<div class="empty-state"><div class="icon">⚠️</div><p>Error al cargar datos. Revisa que el Sheet esté compartido como público de lectura.</p></div>`;
    } finally {
      document.getElementById('btn-actualizar').textContent = '↻ Actualizar';
      const ld = document.getElementById('loading');
      if (ld) ld.style.display = 'none';
    }
  }

  setTimeout(() => { const ld = document.getElementById('loading'); if (ld) ld.style.display = 'none'; }, 5000);

  cargarDatos();
</script>
</body>
</html>
